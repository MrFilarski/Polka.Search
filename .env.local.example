# Google Places API — zdjęcia z Google dla każdego miejsca
# 1. Wejdź na https://console.cloud.google.com/
# 2. Utwórz projekt → APIs & Services → Enable "Places API"
# 3. Credentials → Create API Key → ogranicz do "Places API"
# $200 darmowego kredytu/miesiąc wystarczy na ~100 000 zdjęć
# Bez klucza używane są zdjęcia tematyczne z Unsplash (wg kategorii)
GOOGLE_PLACES_API_KEY=twoj_klucz_tutaj

# Ticketmaster Discovery API — darmowy klucz: https://developer.ticketmaster.com/
# Zarejestruj się, utwórz aplikację, skopiuj "Consumer Key" i wklej poniżej.
# Bez tego klucza wyświetlane są tylko miejsca z OpenStreetMap (biznesy).
TICKETMASTER_API_KEY=twoj_klucz_tutaj
